# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- football-data.org (free token: https://www.football-data.org/client/register) ---
FOOTBALL_DATA_TOKEN=your-football-data-token

# --- Cron protection (any long random string) ---
CRON_SECRET=change-me-to-a-long-random-string

# Optional: override the competition code (default WC = FIFA World Cup)
FOOTBALL_DATA_COMPETITION=WC
